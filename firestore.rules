rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Phase 3: Primitive Definitions
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "phonkphonkswe@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // -------------------------------------------------------------------------
    // Pillar 2: Validation Blueprints
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 32 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 64)) &&
             (!('robux' in data) || data.robux is number) &&
             (!('drovis' in data) || data.drovis is number) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 1000)) &&
             (!('avatarConfig' in data) || data.avatarConfig is map) &&
             (!('rank' in data) || data.rank is string);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'title', 'creatorUid']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.creatorUid == request.auth.uid &&
             (!('mapData' in data) || data.mapData is list);
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'url', 'creatorUid']) &&
             data.id is string && data.id.size() <= 128 &&
             data.url is string && data.url.size() <= 2000 &&
             data.creatorUid == request.auth.uid &&
             (!('likes' in data) || (data.likes is list && data.likes.size() <= 10000));
    }

    // -------------------------------------------------------------------------
    // Match Blocks
    // -------------------------------------------------------------------------

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins Collection
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Users Collection
    match /users/{uid} {
      allow get: if isSignedIn() && isValidId(uid);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(uid) && 
                      isValidUser(incoming()) && 
                      incoming().uid == uid &&
                      (!('robux' in incoming()) || incoming().robux == 0) &&
                      (!('drovis' in incoming()) || incoming().drovis == 0) &&
                      (!('rank' in incoming()) || incoming().rank == 'Bronce');
      
      allow update: if (isOwner(uid) || isAdmin()) && 
                      isValidUser(incoming()) &&
                      (
                        isAdmin() || (
                          incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'avatarConfig', 'settings', 'gallery', 'isUpdated']) &&
                          incoming().uid == existing().uid
                        ) || (
                          incoming().diff(existing()).affectedKeys().hasOnly(['friends'])
                        )
                      );
    }

    // Users by Username Index
    match /users_by_username/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(incoming().uid) && isValidUser(incoming());
      allow update: if (isOwner(existing().uid) || isAdmin()) && isValidUser(incoming());
      allow delete: if (isOwner(existing().uid) || isAdmin());
    }

    // Studio Maps
    match /studio_maps/{username} {
      allow get: if true;
      allow list: if false;
      allow write: if isOwner(get(/databases/$(database)/documents/users_by_username/$(username)).data.uid);
    }

    // Games Collection
    match /games/{gameId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidGame(incoming()) && gameId == incoming().id;
      allow update: if (existing().creatorUid == request.auth.uid || isAdmin()) && 
                      isValidGame(incoming()) &&
                      incoming().creatorUid == existing().creatorUid; 
      allow delete: if existing().creatorUid == request.auth.uid || isAdmin();
    }

    // Videos Collection
    match /videos/{videoId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidVideo(incoming()) && videoId == incoming().id;
      allow update: if (existing().creatorUid == request.auth.uid || isAdmin()) || (
                        isSignedIn() &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['likes']) &&
                        isValidVideo(incoming())
                      );
      allow delete: if existing().creatorUid == request.auth.uid || isAdmin();
    }

    // Global Settings
    match /global_settings/{settingId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }
  }
}
